{
  "name": "agent-decision-log-skill",
  "version": "0.1.0",
  "description": "Local-first agent skill for validating and rendering auditable agent decision logs.",
  "type": "module",
  "bin": {
    "agent-decision-log": "./bin/agent-decision-log.js"
  },
  "scripts": {
    "test": "node --test",
