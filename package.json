    "smoke": "node bin/agent-decision-log.js render fixtures/decision.valid.json --format markdown"
  },
  "keywords": [
    "agent",
    "skill",
    "audit",
    "decision-log",
    "handoff"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "files": [
    "bin",
    "src",
    "docs",
    "fixtures",
    "SKILL.md",
    "README.md",
    "LICENSE"
  ]
}
