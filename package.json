{
  "name": "agent-decision-log-skill",
  "version": "0.1.0",
  "description": "Local-first agent skill for validating and rendering auditable agent decision logs.",
  "type": "module",
  "bin": {
    "agent-decision-log": "./bin/agent-decision-log.js"
  },
  "scripts": {
    "test": "node --test",
    "check": "node --check bin/agent-decision-log.js && node --check src/index.js",
    "smoke": "node bin/agent-decision-log.js render fixtures/decision.valid.json --format markdown",
    "package:smoke": "npm pack --dry-run --ignore-scripts",
    "release:check": "npm run check && npm test && npm run smoke && npm run package:smoke"
  },
  "keywords": [
    "agent",
    "skill",
    "audit",
    "decision-log",
    "handoff"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rogerchappel/agent-decision-log-skill.git"
  },
  "bugs": {
    "url": "https://github.com/rogerchappel/agent-decision-log-skill/issues"
  },
  "homepage": "https://github.com/rogerchappel/agent-decision-log-skill#readme",
  "engines": {
    "node": ">=18"
  },
  "files": [
    "bin",
    "src",
    "docs",
    "fixtures",
    "SKILL.md",
    "README.md",
    "LICENSE"
  ]
}
